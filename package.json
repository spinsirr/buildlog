{
  "name": "buildlog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "bun tests/harness/run.ts",
    "harness:live": "bun tests/harness/run.ts --live",
    "backend:lint": "deno lint supabase/functions/",
    "backend:fmt": "deno fmt --check supabase/functions/",
    "backend:check": "deno lint supabase/functions/ && deno fmt --check supabase/functions/",
    "secrets:local": "./scripts/sync-secrets-to-local.sh",
    "secrets:supabase": "./scripts/sync-secrets-to-supabase.sh",
    "secrets:dev": "infisical run --env=dev -- bun run dev"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "ai": "^6.0.146",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "onborda": "^1.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 90",
    "Edge >= 90",
    "Safari >= 15.4"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "eslint-plugin-vercel-ai-security": "^1.3.5",
    "shadcn": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
